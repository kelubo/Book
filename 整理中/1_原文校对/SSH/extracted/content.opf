    <dc:publisher>O'Reilly Media</dc:publisher>
    <meta name="calibre:title_sort" content="SSH, the Secure Shell, 2nd Edition"/>
    <dc:description>&lt;p&gt;SSH is a popular protocol for securing your network connections. It's reliable, robust, and reasonably easy to use, and both free and commercial implementations are widely available for most operating systems. Everything you want to know about SSH is in our second edition of SSH, The Secure Shell: The Definitive Guide. This updated book thoroughly covers the latest SSH-2 protocol for system administrators and end users.&lt;/p&gt;</dc:description>
    <dc:language>en</dc:language>
    <dc:creator opf:file-as="Byrnes, Daniel J. Barrett;Richard E. Silverman;Robert G." opf:role="aut">Daniel J. Barrett;Richard E. Silverman;Robert G. Byrnes</dc:creator>
    <meta name="calibre:timestamp" content="2011-07-21T07:44:20+00:00"/>
    <dc:title>SSH, the Secure Shell, 2nd Edition</dc:title>
    <meta name="cover" content="cover"/>
